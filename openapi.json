{
  "openapi": "3.1.0",
  "info": {
    "title": "Deco Agent API",
    "description": "High-precision technical diving gas management and decompression planning utility.",
    "version": "2.1.0"
  },
  "paths": {
    "/api/gases": {
      "get": {
        "summary": "Get standard diving gases",
        "operationId": "get_gases_api_gases_get",
        "responses": {
          "200": {
            "description": "List of available gases",
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/GasMix"
                  },
                  "type": "array",
                  "title": "Response Get Gases Api Gases Get"
                }
              }
            }
          }
        }
      }
    },
    "/api/cylinders": {
      "get": {
        "summary": "Get standard cylinder sizes",
        "operationId": "get_cylinders_api_cylinders_get",
        "responses": {
          "200": {
            "description": "List of available cylinders",
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "additionalProperties": true,
                    "type": "object"
                  },
                  "type": "array",
                  "title": "Response Get Cylinders Api Cylinders Get"
                }
              }
            }
          }
        }
      }
    },
    "/api/plan": {
      "post": {
        "summary": "Calculate a dive plan",
        "operationId": "plan_dive_api_plan_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DivePlanRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Detailed dive schedule and gas requirements",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DivePlanResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "DivePlanRequest": {
        "properties": {
          "depth": {
            "type": "number",
            "title": "Depth"
          },
          "bottom_time": {
            "type": "number",
            "title": "Bottom Time"
          },
          "bottom_gas": {
            "type": "string",
            "title": "Bottom Gas"
          },
          "deco_gases": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Deco Gases"
          },
          "gf_low": {
            "type": "number",
            "title": "Gf Low",
            "default": 50
          },
          "gf_high": {
            "type": "number",
            "title": "Gf High",
            "default": 80
          },
          "is_ccr": {
            "type": "boolean",
            "title": "Is Ccr",
            "default": false
          },
          "setpoint": {
            "type": "number",
            "title": "Setpoint",
            "default": 1.2
          },
          "deco_setpoint": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Deco Setpoint",
            "default": 1.2
          },
          "descent_rate": {
            "type": "number",
            "title": "Descent Rate",
            "default": 20.0
          },
          "ascent_rate": {
            "type": "number",
            "title": "Ascent Rate",
            "default": 10.0
          },
          "force_6m": {
            "type": "boolean",
            "title": "Force 6M",
            "default": true
          },
          "model": {
            "type": "string",
            "title": "Model",
            "default": "C"
          }
        },
        "type": "object",
        "required": [
          "depth",
          "bottom_time",
          "bottom_gas",
          "deco_gases"
        ],
        "title": "DivePlanRequest"
      },
      "DivePlanResponse": {
        "properties": {
          "schedule": {
            "items": {
              "$ref": "#/components/schemas/ScheduleEntry"
            },
            "type": "array",
            "title": "Schedule"
          },
          "profile": {
            "items": {
              "$ref": "#/components/schemas/ProfileEntry"
            },
            "type": "array",
            "title": "Profile"
          },
          "gas_requirements": {
            "$ref": "#/components/schemas/GasRequirements"
          },
          "cns_percent": {
            "type": "number",
            "title": "Cns Percent"
          },
          "otus": {
            "type": "number",
            "title": "Otus"
          },
          "tissue_loads": {
            "items": {
              "$ref": "#/components/schemas/TissueLoad"
            },
            "type": "array",
            "title": "Tissue Loads"
          },
          "surface_gf": {
            "type": "number",
            "title": "Surface Gf"
          },
          "warnings": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Warnings"
          }
        },
        "type": "object",
        "required": [
          "schedule",
          "profile",
          "gas_requirements",
          "cns_percent",
          "otus",
          "tissue_loads",
          "surface_gf",
          "warnings"
        ],
        "title": "DivePlanResponse"
      },
      "GasMix": {
        "properties": {
          "name": {
            "type": "string",
            "title": "Name"
          },
          "fO2": {
            "type": "number",
            "title": "Fo2"
          },
          "fHe": {
            "type": "number",
            "title": "Fhe"
          },
          "type": {
            "type": "string",
            "title": "Type"
          }
        },
        "type": "object",
        "required": [
          "name",
          "fO2",
          "fHe",
          "type"
        ],
        "title": "GasMix"
      },
      "GasRequirements": {
        "properties": {
          "bailout": {
            "additionalProperties": {
              "type": "number"
            },
            "type": "object",
            "title": "Bailout"
          },
          "onboard": {
            "additionalProperties": {
              "type": "number"
            },
            "type": "object",
            "title": "Onboard"
          }
        },
        "type": "object",
        "required": [
          "bailout",
          "onboard"
        ],
        "title": "GasRequirements"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "ProfileEntry": {
        "properties": {
          "time": {
            "type": "number",
            "title": "Time"
          },
          "depth": {
            "type": "number",
            "title": "Depth"
          },
          "gas": {
            "type": "string",
            "title": "Gas"
          }
        },
        "type": "object",
        "required": [
          "time",
          "depth",
          "gas"
        ],
        "title": "ProfileEntry"
      },
      "ScheduleEntry": {
        "properties": {
          "depth": {
            "type": "number",
            "title": "Depth"
          },
          "time": {
            "type": "number",
            "title": "Time"
          },
          "run_time": {
            "type": "number",
            "title": "Run Time"
          },
          "gas": {
            "type": "string",
            "title": "Gas"
          },
          "cns": {
            "type": "number",
            "title": "Cns"
          },
          "otu": {
            "type": "number",
            "title": "Otu"
          }
        },
        "type": "object",
        "required": [
          "depth",
          "time",
          "run_time",
          "gas",
          "cns",
          "otu"
        ],
        "title": "ScheduleEntry"
      },
      "TissueLoad": {
        "properties": {
          "compartment": {
            "type": "integer",
            "title": "Compartment"
          },
          "n2_pressure": {
            "type": "number",
            "title": "N2 Pressure"
          },
          "he_pressure": {
            "type": "number",
            "title": "He Pressure"
          },
          "total_pressure": {
            "type": "number",
            "title": "Total Pressure"
          },
          "load_percent": {
            "type": "number",
            "title": "Load Percent"
          }
        },
        "type": "object",
        "required": [
          "compartment",
          "n2_pressure",
          "he_pressure",
          "total_pressure",
          "load_percent"
        ],
        "title": "TissueLoad"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}